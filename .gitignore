.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
*.sys

# Linux
*~
.fuse_hidden*
.directory
.trash

# --------------------------------------------------------------------
# Entornos de Desarrollo (IDEs) y Editores
