.vscode/
!.vscode/extensions.json
*.code-workspace
.history/

# IntelliJ IDEA (Java)
.idea/
*.iws
*.iml
*.ipr
out/

# Eclipse & NetBeans
.metadata
bin/
tmp/
.tmp/
.classpath
.project
.settings/
**/nbproject/private/
**/nbbuild/

# --------------------------------------------------------------------
# Java / Spring Boot / Build Tools
# --------------------------------------------------------------------
# Archivos compilados
*.class
*.log
logs/
**/logs/

# Compilación y empaquetado (Maven y Gradle)
target/
build/
.gradle/
pom.xml.tag
release.properties
.mvn/timing.properties

# Archivos pesados/generados (JARs/WARs)
*.jar
*.war
*.ear
*.zip
*.tar.gz

# --------------------------------------------------------------------
# Python & Data Science
# --------------------------------------------------------------------
# Byte-compiled / optimizados
__pycache__/
*.py[cod]
*$py.class
*.so

# Entornos virtuales (¡CRUCIAL no subirlos!)
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Jupyter Notebooks y empaquetado
.ipynb_checkpoints
dist/
build/
*.egg-info/
.eggs/

# --------------------------------------------------------------------
# Node.js / React Native / Frontend
# --------------------------------------------------------------------
# Dependencias (¡Nunca subir esta carpeta!)
node_modules/
jspm_packages/
.npm

# Caché de TypeScript y logs de error
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Expo y compilaciones nativas de React Native
.expo/*
.eas/
